# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real tokens.

# Hugging Face write token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adaption Labs API key (Settings -> API keys, prefix "pt_live_")
ADAPTION_API_KEY=pt_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
